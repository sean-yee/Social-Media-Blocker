{
  "name": "Lebron James Social Media Blocker",
  "description": "Blocks distracting social media sites. Allows customization for what sites get blocked.",
  "version": "2.1",
  "manifest_version": 3,
  "permissions": ["declarativeNetRequest", "storage", "webNavigation"],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [{
    "resources": ["blocked_page.html", "audio/blocked-by-james.mp3"],
    "matches": ["<all_urls>"]
  }],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "images/lebron.png"
  }
}
